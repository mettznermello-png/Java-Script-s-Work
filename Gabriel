algoritmo "Peso da pessoa"

var
   peso: inteiro
   altura: real
   IMC: real

inicio

   escreval("digite seu peso:")
   leia(peso)
   escreval("digite sua altura:")
   leia(altura)
   IMC <- peso/ (altura*altura)
   escreval("seu IMC é ", IMC)

   fimalgoritmo


