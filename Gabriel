algoritmo"Perimitro em centimetros"

var
    raio: Inteiro
   perimetro: real
inicio 

   escreval("Digite o raio:")
   leia(raio)
   perimetro <- 2 * 3,14159 *raio
   escreval("o perimetro é, ", perimetro ,"cm")

   fimalgoritmo

